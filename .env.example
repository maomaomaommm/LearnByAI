# AI provider configuration is per-user via web UI. No server-side defaults.
# Users must fill apiKey, baseUrl and model in "模型设置".
AI_MOCK_MODE=false
MODEL_TEST_TIMEOUT_MS=30000

# Optional per-agent overrides. Leave empty to require user default.
ARCHITECT_API_BASE_URL=
ARCHITECT_API_KEY=
ARCHITECT_MODEL=
ARCHITECT_TEMPERATURE=
ARCHITECT_MAX_TOKENS=
ARCHITECT_TIMEOUT_MS=
ARCHITECT_THINKING=

AUTHOR_API_BASE_URL=
AUTHOR_API_KEY=
AUTHOR_MODEL=
AUTHOR_TEMPERATURE=
AUTHOR_MAX_TOKENS=
AUTHOR_TIMEOUT_MS=
AUTHOR_THINKING=

POLISHER_API_BASE_URL=
POLISHER_API_KEY=
POLISHER_MODEL=
POLISHER_TEMPERATURE=
POLISHER_MAX_TOKENS=
POLISHER_TIMEOUT_MS=
POLISHER_THINKING=

REVIEWER_API_BASE_URL=
REVIEWER_API_KEY=
REVIEWER_MODEL=
REVIEWER_TEMPERATURE=
REVIEWER_MAX_TOKENS=
REVIEWER_TIMEOUT_MS=
REVIEWER_THINKING=

TUTOR_API_BASE_URL=
TUTOR_API_KEY=
TUTOR_MODEL=
TUTOR_TEMPERATURE=
TUTOR_MAX_TOKENS=
TUTOR_TIMEOUT_MS=
TUTOR_THINKING=

# REVISER drives reading-time local rewrite/repair (the Revise panel). It is a
# content agent: it uses each user's web-configured model just like AUTHOR, and
# is never a server-side fallback for the other agents. Leave empty to inherit
# the shared/default config; set these only to point rewriting at a dedicated model.
REVISER_API_BASE_URL=
REVISER_API_KEY=
REVISER_MODEL=
REVISER_TEMPERATURE=
REVISER_MAX_TOKENS=
REVISER_TIMEOUT_MS=
REVISER_THINKING=

# Web research (联网检索) — server-side search infrastructure for the "纳入最新进展"
# toggle, independent of the per-user agent models above. Three-tier fallback:
# Exa -> StepFun -> Kimi $web_search. Leave a key empty to skip that tier.
# KIMI_SEARCH_* is a dedicated Moonshot/Kimi key used ONLY for the 3rd research
# tier — it is never used as a fallback for the content-writing agents.
EXA_API_KEY=
STEP_SEARCH_API_KEY=
KIMI_SEARCH_API_KEY=
KIMI_SEARCH_BASE_URL=https://api.moonshot.cn/v1
KIMI_SEARCH_MODEL=kimi-k2.6

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_EXPORTS_BUCKET=learnbyai-exports
APP_BASE_URL=

# Background generation. Use "external" when a cron/queue calls /api/internal/generation-worker.
# Final Beta strict readiness requires INTERNAL_WORKER_SECRET to be a non-placeholder value with 32+ characters.
GENERATION_WORKER_MODE=inline
INTERNAL_WORKER_SECRET=
GENERATION_WORKER_JOB_ID=
GENERATION_WORKER_LIMIT=
GENERATION_WORKER_REQUEST_TIMEOUT_MS=1200000

# Chinese admin console at /admin. Use a strong password and a 32+ char session secret in production.
LEARNBYAI_ADMIN_USERNAME=
LEARNBYAI_ADMIN_PASSWORD=
LEARNBYAI_ADMIN_SESSION_SECRET=
# Optional: set true only when the public site is served over HTTPS. Leave empty for auto-detect.
LEARNBYAI_ADMIN_COOKIE_SECURE=

# Daily per-user quotas. Leave empty to use code defaults.
QUOTA_CREATE_COURSE=
QUOTA_GENERATE_CHAPTER=
QUOTA_ASK_TUTOR=
QUOTA_EXPORT=
QUOTA_REVISE=

# Final live Beta gates. Keep unset for ordinary local development.
BETA_READINESS_STRICT=
SUPABASE_SMOKE_RLS=
SUPABASE_SMOKE_REQUIRED=
SUPABASE_SMOKE_USER_ID=
WORKER_HANDOFF_REQUIRED=
AI_SMOKE=
AI_SMOKE_REQUIRED=
